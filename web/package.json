{
  "name": "@aion/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm exec tsc -b && npm exec vite build",
    "preview": "vite preview",
    "smoke:routes": "node scripts/route-smoke.mjs",
    "audit:ui-responsive": "node scripts/route-smoke.mjs --screenshots .codex/artifacts/prj1150-v11-ui-responsive-audit --report .codex/artifacts/prj1150-v11-ui-responsive-audit/report.json --screenshot-routes /,/dashboard,/chat,/personality,/settings,/tools --viewports desktop,tablet,mobile",
    "audit:ui-navigation": "node scripts/route-smoke.mjs --navigation-proof --report .codex/artifacts/prj1209-navigation-proof/report.json",
    "test:connector-confirmation": "node scripts/connector-confirmation-characterization.mjs",
    "test:connector-confirmation-browser": "node scripts/connector-confirmation-browser-characterization.mjs",
    "test:connector-confirmation-render": "node scripts/connector-confirmation-render-characterization.mjs",
    "test:chat-transcript": "node scripts/chat-transcript-characterization.mjs",
    "test:chat-markdown": "node scripts/chat-markdown-characterization.mjs",
    "test:tools-directory": "node scripts/tools-directory-characterization.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "daisyui": "^4.12.14",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
